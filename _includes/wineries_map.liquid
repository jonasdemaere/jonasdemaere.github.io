<!-- Winery data injected as JSON for wineries-map.js -->
<script id="wineries-data" type="application/json">
  [
    {% for winery in site.data.wineries %}
    {
      "name": {{ winery.name | jsonify }},
      "country": {{ winery.country | jsonify }},
      "region": {{ winery.region | jsonify }},
      "date_visited": {{ winery.date_visited | jsonify }},
      "lat": {{ winery.lat | default: "null" }},
      "lng": {{ winery.lng | default: "null" }},
      "notes": {{ winery.notes | default: "" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
</script>

<!-- Map container -->
<div
  id="wineries-map"
  style="position: relative; height: 420px; width: 100%; border-radius: 8px; margin-bottom: 2rem; overflow: hidden; z-index: 0;"
></div>

<!-- Load wineries map script after Leaflet -->
<script defer src="{{ '/assets/js/wineries-map.js' | relative_url | bust_file_cache }}"></script>
